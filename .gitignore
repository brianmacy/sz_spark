# ── Scala / sbt build output ─────────────────────────────────────
target/
project/target/
project/project/
.bsp/
*.class

# Metals / Bloop / scala-cli
.metals/
.bloop/
.scala-build/
metals.sbt

# ── Senzing — DO NOT COMMIT (no rights to redistribute the SDK) ──
# Native libs/data/resources staged into the jar at build time, sourced
# from a local licensed install. The FAT jar bundles these but is never
# committed or published.
src/main/resources/native/
**/.debs/
build/libs/
*-assembly-*.jar
# NOTE: config/overrides/ is intentionally NOT ignored — those are the
# user's own customized config files, fine to commit and ship.

# ── Secrets / local runtime config ───────────────────────────────
# SENZING_ENGINE_CONFIGURATION_JSON carries DB connection strings.
.env
.env.*
*.local.conf

# ── Logs / temp ──────────────────────────────────────────────────
*.log
debugging/

# ── FAQ MCP server (Python) ──────────────────────────────────────
.claude/.faq-venv/
__pycache__/
*.pyc

# ── IDE / OS ─────────────────────────────────────────────────────
.idea/
*.iml
.vscode/
.DS_Store
